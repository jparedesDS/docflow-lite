# DocFlow Lite — configuración local
# Copia este archivo a .env y rellena los valores

# IMAP (lectura de correos entrantes)
IMAP_HOST=imap.soljem.com
IMAP_PORT=993
IMAP_USER=documentacion@eipsa.es
IMAP_PASS=

# SMTP (envío de notificaciones de devolución)
SMTP_HOST=smtp.soljem.com
SMTP_PORT=465
SMTP_USER=documentacion@eipsa.es
SMTP_PASS=

# Rutas locales (opcional — por defecto usa ./data/)
# DATA_DIR=
# DATA_ERP_PATH=
# CONSULTA_ERP_PATH=

# Carpeta base de pedidos en red (opcional, para guardar EML)
# PEDIDOS_BASE_PATH=M:\base de datos de pedidos
